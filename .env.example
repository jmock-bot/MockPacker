# ── Frontend (safe to expose — the anon key is protected by Row Level Security) ──
# Found in Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Where OAuth / magic-link / password-reset flows return to. Defaults to the
# current origin when unset. Register each environment's URL in Supabase
# (Authentication → URL Configuration → Redirect URLs):
#   https://your-site.netlify.app
#   http://localhost:8888          (netlify dev)
# The Supabase OAuth callback itself is:
#   https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
VITE_AUTH_REDIRECT_URL=

# ── Server-side only (Netlify Functions). NEVER referenced by frontend code. ──
# Service-role key bypasses RLS — set it only in Netlify's environment settings.
SUPABASE_SERVICE_ROLE_KEY=

# ── Product search (server-side only) ──
# MockPacker never scrapes Google. Product search uses an approved shopping-data
# provider (SerpAPI's Google Shopping engine). Without a key, search shows a
# graceful "not connected yet" state and manual item entry still works.
SERPAPI_KEY=
# ISO country for shopping results (default: us)
SEARCH_COUNTRY=us

# ── Shipment tracking carrier APIs (server-side only, all optional) ──
# Without credentials, MockPacker still tracks shipments manually (statuses,
# ETAs, deep links to each carrier's own tracking page). Add credentials to
# enable live tracking via /api/track-shipment.
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
FEDEX_API_KEY=
FEDEX_SECRET_KEY=
USPS_USER_ID=
DHL_API_KEY=

# ── Weather ──
# Daily forecasts use Open-Meteo (https://open-meteo.com), which requires no
# API key for non-commercial use. To switch providers, set a key here and
# update netlify/functions/weather.ts.
OPENWEATHER_API_KEY=
