# ── Frontend (safe to expose — the browser key is protected by Row Level Security) ──
# Found in Supabase Dashboard → Project Settings → API Keys
VITE_SUPABASE_URL=
# New-style publishable key (sb_publishable_…). This is the browser key and
# replaces the legacy anon key. Set ONE of the two below:
VITE_SUPABASE_PUBLISHABLE_KEY=
# Legacy fallback — still accepted if you haven't migrated to the new keys yet.
VITE_SUPABASE_ANON_KEY=

# Where OAuth / magic-link / password-reset flows return to. Defaults to the
# current origin when unset. Register each environment's URL in Supabase
# (Authentication → URL Configuration → Redirect URLs):
#   https://your-site.netlify.app
#   http://localhost:8888          (netlify dev)
# The Supabase OAuth callback itself is:
#   https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
VITE_AUTH_REDIRECT_URL=

# ── Server-side only (Netlify Functions). NEVER referenced by frontend code. ──
# The functions verify the caller's Supabase token via @supabase/server
# (netlify/functions/_supabaseAuth.ts). They read SUPABASE_URL; if it is unset
# they fall back to VITE_SUPABASE_URL, so on Netlify you usually only need the
# frontend URL above. Set SUPABASE_URL explicitly if you want them decoupled.
SUPABASE_URL=
#
# JWKS is how tokens are verified locally (no round-trip, no secret key needed).
# Optional: when unset it is DERIVED from the project URL as
#   <SUPABASE_URL>/auth/v1/.well-known/jwks.json
# Set SUPABASE_JWKS_URL only to override that, or SUPABASE_JWKS for inline keys.
SUPABASE_JWKS_URL=
#
# New-style secret key (sb_secret_…), the service-role-key replacement. It
# bypasses RLS — set it ONLY in Netlify's environment settings, never in the
# browser build. With the new asymmetric signing keys it is NOT required just
# to authenticate callers; it is used only for the legacy token-verification
# fallback (projects still issuing HS256 tokens). Falls back to
# SUPABASE_SERVICE_ROLE_KEY if you haven't migrated yet.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Product search (server-side only) ──
# MockPacker never scrapes Google. Product search uses an approved shopping-data
# provider (SerpAPI's Google Shopping engine). Without a key, search shows a
# graceful "not connected yet" state and manual item entry still works.
SERPAPI_KEY=
# ISO country for shopping results (default: us)
SEARCH_COUNTRY=us

# ── Shipment tracking carrier APIs (server-side only, all optional) ──
# Without credentials, MockPacker still tracks shipments manually (statuses,
# ETAs, deep links to each carrier's own tracking page). Add credentials to
# enable live tracking via /api/track-shipment.
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
FEDEX_API_KEY=
FEDEX_SECRET_KEY=
USPS_USER_ID=
DHL_API_KEY=

# ── Weather ──
# Daily forecasts use Open-Meteo (https://open-meteo.com), which requires no
# API key for non-commercial use. To switch providers, set a key here and
# update netlify/functions/weather.ts.
OPENWEATHER_API_KEY=
